{
  "version": 2,
  "builds": [
    {
      "src": "src/main.rs",
      "use": "vercel-rust"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "src/main.rs" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}








